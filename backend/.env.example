PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/gym_saas
JWT_SECRET=<generate-a-64-char-hex-string>
NODE_ENV=production
CLIENT_URL=https://your-frontend.vercel.app/

# Encryption key for storing Razorpay secrets in DB (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, falls back to JWT_SECRET (backward-compatible)
# Once set in production, DO NOT change without re-saving all Razorpay configs
ENCRYPTION_KEY=<generate-a-64-char-hex-string>

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

EMAIL_USER=
EMAIL_PASS=

GEMINI_API_KEY=

ADMIN_RECOVERY_SECRET=<generate-a-64-char-hex-string>

# Razorpay — get these from dashboard.razorpay.com
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET — set this in Razorpay Dashboard > Webhooks > Secret
# Then add the exact same secret here. Required for webhook signature verification.
RAZORPAY_WEBHOOK_SECRET=

# Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=